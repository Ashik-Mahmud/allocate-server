generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  password           String
  name               String
  photo              String?
  personal_credits   Int?
  role               Role           @default(ORG_ADMIN)
  last_login         DateTime?
  is_verified        Boolean?       @default(false)
  verification_token String?        @unique
  token_expiry       DateTime?
  deletedAt          DateTime?
  createdAt          DateTime?      @default(now())
  updatedAt          DateTime?      @updatedAt
  org_id             String?
  organization       Organizations? @relation(fields: [org_id], references: [id], onDelete: Cascade)
  notifications      Notification[]
  bookings           Bookings[]     @relation("BookingUser")
  createdBookings    Bookings[]     @relation("BookingCreator")

  @@index([email, org_id])
  @@map("users")
  creditTransactions CreditTransaction[]
}

model Organizations {
  id             String          @id @default(cuid())
  name           String
  slug           String?         @unique
  org_type       String?
  tagline        String?
  photo          String?
  plan_type      PlanType?       @default(FREE)
  credit_pool    Int?            @default(100)
  is_active      Boolean?        @default(true)
  timezone       String          @default("UTC")
  address        Json?
  business_email String?
  needUpdateOrg  Boolean?        @default(true)
  settings       Json?            @default("{\"notificationPreference\":{\"email\":true,\"sms\":false,\"push\":false, \"inApp\":true}}") // For future extensibility (e.g. notification preferences, etc.)
  isVerified      Boolean?        @default(false)
  deletedAt      DateTime?
  createdAt      DateTime?       @default(now())
  updatedAt      DateTime?       @updatedAt
  users          User[]
  resources      Resources[]
  subscriptions  Subscription[]
  resourcesRules ResourcesRule[]
  notifications  Notification[]
  invitations    Invitation[]
  bookings       Bookings[]

  @@index([name, id])
  @@map("organizations")
}

model Resources {
  id             String          @id @default(cuid())
  org_id         String
  organization   Organizations   @relation(fields: [org_id], references: [id], onDelete: Cascade)
  name           String
  type           String
  hourly_rate    Decimal
  metadata       Json
  is_available   Boolean
  is_active      Boolean
  is_maintenance Boolean
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  resourcesRules ResourcesRule[]
  bookings       Bookings[]

  @@index([org_id])
  @@map("resources")
}

model ResourcesRule {
  id                 String        @id @default(cuid())
  org_id             String
  organization       Organizations @relation(fields: [org_id], references: [id], onDelete: Cascade)
  resource_id        String        @unique
  resource           Resources     @relation(fields: [resource_id], references: [id], onDelete: Cascade)
  max_booking_hours  Float?
  min_lead_time      Float?
  buffer_time        Float?
  opening_hours      Int?          @default(9) // in 24h format, e.g. 9 for 9 AM
  closing_hours      Int?          @default(18) // in 24h format, e.g. 17
  slot_duration_min  Int           @default(30) // in minutes
  is_weekend_allowed Boolean       @default(false)
  availableDays      Json?         @default("[]") // e.g. ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"]
  deletedAt          DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([org_id, resource_id])
  @@map("resources_rules")
}

model Subscription {
  id             String         @id @default(cuid())
  org_id         String
  organization   Organizations  @relation(fields: [org_id], references: [id], onDelete: Cascade)
  plan_name      PlanType
  start_date     DateTime
  end_date       DateTime?
  payment_status PaymentStatus?
  is_active      Boolean?       @default(true)
  deletedAt      DateTime?
  createdAt      DateTime?      @default(now())
  updatedAt      DateTime?      @updatedAt

  @@index([org_id])
  @@map("subscriptions")
}

model Bookings {
  id                  String         @id @default(cuid())
  user_id             String
  resource_id         String
  org_id              String
  created_by          String?
  start_time          DateTime
  end_time            DateTime
  total_cost          Int?           @default(0) // Calculated based on resource hourly_rate and duration
  status              BookingStatus? @default(PENDING)
  cancellation_reason String?
  notes               String?
  metadata            Json?
  deletedAt           DateTime?
  createdAt           DateTime?      @default(now())
  updatedAt           DateTime?      @updatedAt

  user               User                @relation("BookingUser", fields: [user_id], references: [id], onDelete: Cascade)
  organization       Organizations       @relation(fields: [org_id], references: [id], onDelete: Cascade)
  resource           Resources           @relation(fields: [resource_id], references: [id], onDelete: Cascade)
  creator            User?               @relation("BookingCreator", fields: [created_by], references: [id], onDelete: SetNull)
  creditTransactions CreditTransaction[]

  @@index([user_id, resource_id, org_id, status])
  @@map("bookings")
}

model CreditTransaction {
  id              String          @id @default(uuid())
  org_id          String
  user_id         String
  amount          Float // +50.00 or -10.00
  type            TransactionType // Enum: SPEND, ALLOCATE, REFUND
  previousBalance Float
  currentBalance  Float
  referenceId     String? // Booking ID or Top-up ID
  description     String?
  performedBy     String // Admin ID who performed the action
  createdAt       DateTime        @default(now())

  booking Bookings? @relation(fields: [referenceId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([org_id, user_id])
  @@map("credit_transactions")
}

model Notification {
  id           String           @id @default(cuid())
  user_id      String
  org_id       String
  type         NotificationType
  title        String
  message      String
  is_read      Boolean          @default(false)
  reference_id String?  // e.g. Booking ID, Credit Transaction ID, etc.
  metadata     Json?    // Additional data related to the notification

  user         User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization Organizations @relation(fields: [org_id], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([user_id, org_id, is_read])
  @@map("notifications")
}

model ActivityLog {
  id        String   @id @default(cuid())
  org_id    String
  user_id   String
  action    String
  ipAddress String
  userAgent String
  metadata  Json?
  createdAt DateTime @default(now())
  details String?

  @@index([org_id, user_id])
  @@map("activity_logs")
}

model SystemSettings {
  id                   String   @id @default("default")
  maintenance_mode     Boolean  @default(false)
  global_alert_message Json?
  support_email        String?
  features_flags       Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("system_settings")
}

model Invitation {
  id        String           @id @default(cuid())
  org_id    String
  email     String
  role      Role             @default(ORG_ADMIN)
  token     String           @unique
  expiresAt DateTime
  status    InvitationStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  organization Organizations @relation(fields: [org_id], references: [id], onDelete: Cascade)

  @@index([org_id, email])
  @@map("invitations")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  COMPLETED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum NotificationType {
  // Booking Related
  BOOKING_REQUESTED
  BOOKING_CONFIRMED
  BOOKING_REJECTED
  BOOKING_REMINDER 
  BOOKING_CANCELLED

  // Credit Related
  CREDIT_RECEIVED
  CREDIT_REVOKED 
  LOW_CREDIT_WARNING 

  // Invitation & Staff
  INVITATION_RECEIVED
  STAFF_JOINED 

  // Subscription (Paid Feature)
  SUBSCRIPTION_EXPIRING 
  SUBSCRIPTION_EXPIRED 

  // System
  SYSTEM_ALERT
  MAINTENANCE_NOTICE 
}

enum TransactionType {
  // Admin to Staff
  ALLOCATE      // When admin allocates credits to staff
  REVOKE        // When admin revokes credits from staff

  // Staff Usage
  SPEND         // When staff spend credits
  REFUND        // When staff are refunded credits

  // Organization Pool (System Admin to Org Admin)
  TOP_UP        // When system admin adds credits to an organization's main pool
  DEDUCT        // When credits are deducted from an organization's pool for a specific reason

  // Bonus/System
  ADJUSTMENT    // When the balance needs to be adjusted due to an error or other reason
}

enum Role {
  STAFF
  ADMIN
  ORG_ADMIN
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  OVERDUE
}

enum PlanType {
  FREE
  PRO
  ENTERPRISE
}
