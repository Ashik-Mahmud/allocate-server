generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  password         String
  name             String
  photo            String?
  personal_credits Int?
  role             Role           @default(CLIENT)
  last_login       DateTime?
  deletedAt        DateTime?
  createdAt        DateTime?      @default(now())
  updatedAt        DateTime?      @updatedAt
  org_id           String?
  organization     Organizations? @relation(fields: [org_id], references: [id], onDelete: Cascade)

  @@map("users")
}

model Organizations {
  id          String    @id @default(cuid())
  name        String
  org_type    String?
  tagline     String?
  photo       String?
  plan_type   PlanType? @default(FREE)
  credit_pool Int?      @default(100)
  is_active   Boolean?  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt
  users       User[]

  @@map("organizations")
}

model Resources {
  id           String    @id @default(cuid())
  org_id       String
  name         String
  type         String
  metadata     Json
  is_available Boolean
  is_active    Boolean
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("resources")
}

enum Role {
  STAFF
  ADMIN
  CLIENT
}

enum PayrollStatus {
  PENDING
  PROCESSED
  PAID
}

enum PlanType {
  FREE
  PRO
  ENTERPRISE
}
